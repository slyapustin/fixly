{
    "manifest_version": 3,
    "name": "AI Text Fixer",
    "version": "1.2.0",
    "description": "Fix selected text anywhere on the web using OpenAI API or locally running Ollama models.",
    "permissions": [
        "storage",
        "activeTab",
        "contextMenus"
    ],
    "host_permissions": [
        "https://api.openai.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://*.local/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end",
            "all_frames": true
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "commands": {
        "fix-selection": {
            "suggested_key": {
                "default": "Ctrl+Shift+F",
                "mac": "Command+Shift+F"
            },
            "description": "Fix selected text with Fixly"
        }
    }
}